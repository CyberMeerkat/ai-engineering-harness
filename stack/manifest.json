{
  "sharedMcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
      "enabledByDefault": true
    },
    "context7": {
      "type": "local",
      "command": ["context7-mcp"],
      "enabledByDefault": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabledByDefault": false,
      "oauth": true,
      "notes": "Per-user OAuth"
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/sse",
      "enabledByDefault": false,
      "notes": "Requires local bridge"
    }
  },
  "opencode": {
    "plugins": [
      "context-mode"
    ],
    "projectSkillsSources": [
      "harness/skills/opencode"
    ],
    "globalSkillsSources": [
      "harness/skills/opencode",
      "harness/skills/shared"
    ]
  }
}
