{
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "Bash(gh variable:*)",
      "Bash(gh workflow:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(docker push:*)",
      "Bash(docker manifest:*)",
      "Bash(osascript:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "{{HOME}}/.claude/plans"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/check-generated-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/check-destructive-ops.sh"
          },
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/strip-jwt-permissions.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/check-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/check-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Read|Search",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-code-discovery-gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CAVEMEM_PATH}} hook run post-tool-use --ide claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CAVEMEM_PATH}} hook run user-prompt-submit --ide claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CAVEMEM_PATH}} hook run stop --ide claude-code"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CAVEMEM_PATH}} hook run session-start --ide claude-code"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-session-reminder"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-session-reminder"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-session-reminder"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-session-reminder"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{HOME}}/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/learned-reindex.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CAVEMEM_PATH}} hook run session-end --ide claude-code"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 -c \"\nimport json,sys,os,subprocess\nd=json.load(sys.stdin)\ncwd=d.get('workspace',{}).get('current_dir') or d.get('cwd','')\ndir_name=os.path.basename(cwd)\nbranch=''\ntry:\n  r=subprocess.run(['git','-C',cwd,'symbolic-ref','--short','HEAD','--no-optional-locks'],capture_output=True,text=True)\n  branch=r.stdout.strip()\nexcept:pass\nmodel=d.get('model',{}).get('display_name','') or d.get('model',{}).get('id','')\nmodel=model.replace('Claude ','').replace(' Sonnet','S').replace(' Haiku','H').replace(' Opus','O')\nused=d.get('context_window',{}).get('used_percentage')\nvim_mode=d.get('vim',{}).get('mode','')\nfive=d.get('rate_limits',{}).get('five_hour',{}).get('used_percentage')\nweek=d.get('rate_limits',{}).get('seven_day',{}).get('used_percentage')\nsess=d.get('session_name','')\nagent=d.get('agent',{}).get('name','') if d.get('agent') else ''\nwt=d.get('worktree',{}).get('branch','') if d.get('worktree') else ''\nif wt: branch='wt:'+wt\nC={'cyan':'\\\\033[36m','purple':'\\\\033[35m','blue':'\\\\033[34m','grey':'\\\\033[90m','green':'\\\\033[32m','yellow':'\\\\033[33m','red':'\\\\033[31m','reset':'\\\\033[0m'}\nparts=[]\nbl=C['cyan']+dir_name+C['reset']\nif branch: bl+=(' '+C['purple']+'('+branch+')'+C['reset'])\nparts.append(bl)\nif model: parts.append(C['blue']+model+C['reset'])\nif used is not None:\n  u=round(used)\n  cc=C['red'] if u>=80 else C['yellow'] if u>=50 else C['green']\n  parts.append(cc+'ctx:'+str(u)+'%'+C['reset'])\nif five is not None: parts.append(C['yellow']+'5h:'+str(round(five))+'%'+C['reset'])\nif week is not None: parts.append(C['yellow']+'7d:'+str(round(week))+'%'+C['reset'])\nif vim_mode: parts.append((C['green']+'INS' if vim_mode=='INSERT' else C['yellow']+'NRM')+C['reset'])\nif agent: parts.append(C['purple']+'agent:'+agent+C['reset'])\nif sess: parts.append(C['grey']+'['+sess+']'+C['reset'])\nsep=C['grey']+' | '+C['reset']\nprint(sep.join(parts))\n\""
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "figma@claude-plugins-official": true,
    "watch@claude-video": true,
    "obsidian@obsidian-skills": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-video": {
      "source": {
        "source": "github",
        "repo": "bradautomates/claude-video"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "light-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "cavemem": {
      "command": "{{CAVEMEM_PATH}}",
      "args": [
        "mcp"
      ]
    }
  }
}
